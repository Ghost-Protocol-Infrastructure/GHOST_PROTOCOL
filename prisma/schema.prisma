generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

enum AgentTier {
  WHALE
  ACTIVE
  NEW
  GHOST
}

enum SnapshotStatus {
  BUILDING
  READY
  FAILED
}

enum CanonicalAddressSource {
  OLAS_AGENT
  ERC8004_RESOLVED
  MANUAL_OVERRIDE
  AGENT_ADDRESS
  NONE
}

enum TxMetricSource {
  AGENT_ONCHAIN
  USAGE_ACTIVITY_7D
  OWNER_FALLBACK
  CREATOR_FALLBACK
  UNRESOLVED
}

enum AgentTxSourceKind {
  AGENT
  OWNER
  CREATOR
  UNRESOLVED
}

enum CreditLedgerDirection {
  CREDIT
  DEBIT
  ADJUSTMENT
}

enum GateAccessOutcome {
  AUTHORIZED
  REPLAY
  INSUFFICIENT_CREDITS
  MALFORMED_AUTH
  SERVICE_MISMATCH
  SIGNATURE_EXPIRED
  INVALID_SIGNATURE
}

enum AgentGatewayReadinessStatus {
  UNCONFIGURED
  CONFIGURED
  LIVE
  DEGRADED
}

enum AgentGatewayCanaryMethod {
  GET
}

enum FulfillmentHoldState {
  HELD
  CAPTURED
  RELEASED
  EXPIRED
}

enum FulfillmentReleaseReason {
  TTL_EXPIRED
  MANUAL
  CAPTURE_FAILED_POLICY
}

enum AgentGatewayDelegatedSignerStatus {
  ACTIVE
  REVOKED
}

enum MerchantEarningSourceType {
  GATE_DEBIT
  FULFILLMENT_CAPTURE
}

enum MerchantEarningStatus {
  PENDING
  SUBMITTED
  CONFIRMED
  FAILED
}

enum MerchantSettlementBatchStatus {
  OPEN
  SUBMITTED
  CONFIRMED
  FAILED
}

enum WireSettlementAsset {
  USDC
}

enum WireReserveAsset {
  ETH
}

enum WireJobType {
  SERVICE
}

enum WireContractState {
  OPEN
  FUNDED
  SUBMITTED
  COMPLETED
  REJECTED
  EXPIRED
}

enum WireTerminalDisposition {
  COMPLETED
  REJECTED
  EXPIRED
}

enum WireWorkflowStatus {
  PENDING
  IN_PROGRESS
  SUCCEEDED
  FAILED
}

enum WireOperatorActionType {
  APPROVE
  CREATE
  FUND
  SUBMIT
  COMPLETE
  REJECT
  EXPIRE
  RECLAIM
}

enum WireWebhookDeliveryStatus {
  PENDING
  DELIVERED
  FAILED
  DEAD_LETTER
}

model CreditBalance {
  walletAddress   String   @id
  credits         Int      @default(0)
  heldCredits     Int      @default(0)
  lastSyncedBlock BigInt   @default(0)
  updatedAt       DateTime @updatedAt

  ledgerEntries    CreditLedger[]
  fulfillmentHolds FulfillmentHold[]
  merchantEarnings MerchantEarning[]
}

model AccessNonce {
  id               String   @id @default(cuid())
  signer           String
  service          String
  nonce            String
  payloadTimestamp BigInt
  signature        String?
  createdAt        DateTime @default(now())

  @@unique([signer, service, nonce])
  @@index([service, signer])
  @@index([createdAt])
}

model ServicePricing {
  service   String   @id
  cost      Int
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CreditLedger {
  id                    String                @id @default(cuid())
  walletAddress         String
  direction             CreditLedgerDirection
  amount                Int
  availableCreditsDelta Int?
  heldCreditsDelta      Int?
  balanceBefore         Int
  balanceAfter          Int
  reason                String
  service               String?
  nonce                 String?
  requestId             String?
  metadata              Json?
  createdAt             DateTime              @default(now())

  wallet CreditBalance @relation(fields: [walletAddress], references: [walletAddress], onDelete: Cascade)

  @@unique([walletAddress, requestId])
  @@index([walletAddress, createdAt])
  @@index([reason, createdAt])
  @@index([service, createdAt])
}

model GateAccessEvent {
  id               String            @id @default(cuid())
  service          String
  signer           String?
  nonce            String?
  requestId        String?
  outcome          GateAccessOutcome
  cost             Int?
  remainingCredits Int?
  metadata         Json?
  createdAt        DateTime          @default(now())

  @@index([createdAt])
  @@index([outcome, createdAt])
  @@index([service, createdAt])
  @@index([signer, createdAt])
}

model TelemetryPulseEvent {
  id           String   @id @default(cuid())
  apiKeyHash   String?
  apiKeyPrefix String?
  agentId      String?
  serviceSlug  String?
  metadata     Json?
  createdAt    DateTime @default(now())

  @@index([createdAt])
  @@index([agentId, createdAt])
  @@index([serviceSlug, createdAt])
  @@index([apiKeyHash, createdAt])
}

model TelemetryOutcomeEvent {
  id           String   @id @default(cuid())
  apiKeyHash   String?
  apiKeyPrefix String?
  agentId      String?
  serviceSlug  String?
  success      Boolean
  statusCode   Int?
  metadata     Json?
  createdAt    DateTime @default(now())

  @@index([createdAt])
  @@index([success, createdAt])
  @@index([agentId, createdAt])
  @@index([serviceSlug, createdAt])
  @@index([apiKeyHash, createdAt])
}

model Agent {
  address     String    @id
  agentId     String    @unique
  name        String
  creator     String
  owner       String
  image       String?
  description String?
  telegram    String?
  twitter     String?
  website     String?
  status      String    @default("active")
  volume      BigInt    @default(0)
  score       Int       @default(0)
  reputation  Float     @default(0)
  rankScore   Float     @default(0)
  tier        AgentTier @default(NEW)
  txCount     Int       @default(0)
  yield       Float     @default(0)
  uptime      Float     @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  scoreInput    AgentScoreInput?
  snapshots     LeaderboardSnapshotRow[]
  gatewayConfig AgentGatewayConfig?
}

model AgentGatewayConfig {
  id                   String                      @id @default(cuid())
  agentId              String                      @unique
  ownerAddress         String
  serviceSlug          String
  endpointUrl          String
  canaryPath           String                      @default("/ghostgate/canary")
  canaryMethod         AgentGatewayCanaryMethod    @default(GET)
  readinessStatus      AgentGatewayReadinessStatus @default(CONFIGURED)
  lastCanaryCheckedAt  DateTime?
  lastCanaryPassedAt   DateTime?
  lastCanaryStatusCode Int?
  lastCanaryLatencyMs  Int?
  lastCanaryError      String?
  createdAt            DateTime                    @default(now())
  updatedAt            DateTime                    @updatedAt

  agent            Agent                         @relation(fields: [agentId], references: [agentId], onDelete: Cascade)
  canaryChecks     AgentGatewayCanaryCheck[]
  delegatedSigners AgentGatewayDelegatedSigner[]
  fulfillmentHolds FulfillmentHold[]

  @@index([ownerAddress])
  @@index([readinessStatus])
  @@index([serviceSlug])
}

model AgentGatewayCanaryCheck {
  id              String   @id @default(cuid())
  gatewayConfigId String
  checkedAt       DateTime @default(now())
  success         Boolean
  statusCode      Int?
  latencyMs       Int?
  error           String?
  responseDigest  String?
  requestId       String?
  createdAt       DateTime @default(now())

  gatewayConfig AgentGatewayConfig @relation(fields: [gatewayConfigId], references: [id], onDelete: Cascade)

  @@index([gatewayConfigId, checkedAt])
  @@index([success, checkedAt])
  @@index([checkedAt])
}

model FulfillmentHold {
  id                     String                    @id @default(cuid())
  ticketId               String                    @unique
  walletAddress          String
  serviceSlug            String
  agentId                String?
  gatewayConfigId        String?
  merchantOwnerAddress   String
  requestMethod          String
  requestPath            String
  queryHash              String
  bodyHash               String
  cost                   Int
  state                  FulfillmentHoldState
  issuedAt               DateTime
  expiresAt              DateTime
  capturedAt             DateTime?
  releasedAt             DateTime?
  releaseReason          FulfillmentReleaseReason?
  captureDeliveryProofId String?
  captureStatusCode      Int?
  captureLatencyMs       Int?
  lastError              String?
  createdAt              DateTime                  @default(now())
  updatedAt              DateTime                  @updatedAt

  wallet          CreditBalance               @relation(fields: [walletAddress], references: [walletAddress], onDelete: Cascade)
  gatewayConfig   AgentGatewayConfig?         @relation(fields: [gatewayConfigId], references: [id], onDelete: SetNull)
  captureAttempts FulfillmentCaptureAttempt[]
  // Partial unique index required via SQL migration:
  // (walletAddress, serviceSlug) WHERE state = 'HELD'

  @@index([walletAddress, state])
  @@index([walletAddress, serviceSlug, state])
  @@index([state, expiresAt])
  @@index([agentId, createdAt])
  @@index([gatewayConfigId, createdAt])
  @@index([captureDeliveryProofId])
}

model FulfillmentCaptureAttempt {
  id                 String   @id @default(cuid())
  holdId             String
  ticketId           String
  deliveryProofId    String
  merchantSigner     String
  receivedAt         DateTime @default(now())
  success            Boolean
  httpStatus         Int
  captureDisposition String?
  errorCode          String?
  errorMessage       String?
  rawMeta            Json?

  hold FulfillmentHold @relation(fields: [holdId], references: [id], onDelete: Cascade)

  @@index([ticketId, receivedAt])
  @@index([holdId, receivedAt])
  @@index([deliveryProofId])
  @@index([merchantSigner, receivedAt])
}

model AgentGatewayDelegatedSigner {
  id              String                            @id @default(cuid())
  gatewayConfigId String
  ownerAddress    String
  signerAddress   String
  status          AgentGatewayDelegatedSignerStatus @default(ACTIVE)
  label           String?
  createdAt       DateTime                          @default(now())
  revokedAt       DateTime?
  updatedAt       DateTime                          @updatedAt

  gatewayConfig AgentGatewayConfig @relation(fields: [gatewayConfigId], references: [id], onDelete: Cascade)

  @@index([gatewayConfigId, status])
  @@index([ownerAddress, status])
  @@index([gatewayConfigId, signerAddress])
  @@index([signerAddress, status])
}

model MerchantSettlementBatch {
  id             String                        @id @default(cuid())
  status         MerchantSettlementBatchStatus @default(OPEN)
  txHash         String?
  submittedAt    DateTime?
  confirmedAt    DateTime?
  failureMessage String?
  createdAt      DateTime                      @default(now())
  updatedAt      DateTime                      @updatedAt

  earnings MerchantEarning[]

  @@index([status, createdAt])
  @@index([submittedAt])
  @@index([confirmedAt])
  @@index([txHash])
}

model MerchantEarning {
  id                   String                    @id @default(cuid())
  settlementId         String                    @unique
  walletAddress        String
  merchantOwnerAddress String
  agentId              String?
  serviceSlug          String
  sourceType           MerchantEarningSourceType
  sourceId             String
  grossCredits         Int
  grossWei             BigInt
  feeWei               BigInt
  netWei               BigInt
  status               MerchantEarningStatus     @default(PENDING)
  allocatorBatchId     String?
  txHash               String?
  failureCode          String?
  failureMessage       String?
  createdAt            DateTime                  @default(now())
  updatedAt            DateTime                  @updatedAt

  wallet         CreditBalance            @relation(fields: [walletAddress], references: [walletAddress], onDelete: Cascade)
  allocatorBatch MerchantSettlementBatch? @relation(fields: [allocatorBatchId], references: [id], onDelete: SetNull)

  @@unique([sourceType, sourceId])
  @@index([status, createdAt])
  @@index([merchantOwnerAddress, status, createdAt])
  @@index([serviceSlug, createdAt])
  @@index([agentId, createdAt])
  @@index([allocatorBatchId, status])
  @@index([txHash])
}

model SystemState {
  key             String @id
  lastSyncedBlock BigInt @default(0)
}

model AgentScoreInput {
  agentAddress            String                 @id
  agentId                 String
  name                    String
  creator                 String
  owner                   String
  image                   String?
  description             String?
  telegram                String?
  twitter                 String?
  website                 String?
  status                  String                 @default("active")
  txSourceAddress         String?
  txSourceKind            AgentTxSourceKind      @default(UNRESOLVED)
  canonicalOnchainAddress String?
  canonicalAddressSource  CanonicalAddressSource @default(NONE)
  txCount                 Int                    @default(0)
  onchainTxCountAgent     Int?
  onchainTxCountOwner     Int                    @default(0)
  usageAuthorizedCount7d  Int                    @default(0)
  metricSource            TxMetricSource         @default(UNRESOLVED)
  yield                   Float                  @default(0)
  uptime                  Float                  @default(0)
  isClaimed               Boolean                @default(false)
  txCountUpdatedAt        DateTime?
  lastIngestedAt          DateTime               @default(now())
  createdAt               DateTime               @default(now())
  updatedAt               DateTime               @updatedAt

  agent Agent @relation(fields: [agentAddress], references: [address], onDelete: Cascade)

  @@index([txSourceAddress])
  @@index([txCountUpdatedAt])
  @@index([canonicalOnchainAddress])
  @@index([metricSource])
}

model LeaderboardSnapshot {
  id              String         @id @default(cuid())
  mode            String
  txSource        String
  status          SnapshotStatus @default(BUILDING)
  isActive        Boolean        @default(false)
  totalAgents     Int            @default(0)
  maxTxCount      Int            @default(0)
  maxClaimedYield Float          @default(0)
  startedAt       DateTime       @default(now())
  completedAt     DateTime?
  failureReason   String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  rows LeaderboardSnapshotRow[]

  @@index([isActive, status])
  @@index([completedAt])
}

model LeaderboardSnapshotRow {
  id                      String                 @id @default(cuid())
  snapshotId              String
  agentAddress            String
  agentId                 String
  name                    String
  creator                 String
  owner                   String
  image                   String?
  description             String?
  telegram                String?
  twitter                 String?
  website                 String?
  status                  String
  rank                    Int
  tier                    AgentTier
  txCount                 Int
  onchainTxCountAgent     Int?
  onchainTxCountOwner     Int                    @default(0)
  usageAuthorizedCount7d  Int                    @default(0)
  metricSource            TxMetricSource         @default(UNRESOLVED)
  canonicalOnchainAddress String?
  canonicalAddressSource  CanonicalAddressSource @default(NONE)
  reputation              Float
  rankScore               Float
  yield                   Float
  uptime                  Float
  volume                  BigInt
  score                   Int
  agentCreatedAt          DateTime
  agentUpdatedAt          DateTime
  createdAt               DateTime               @default(now())
  updatedAt               DateTime               @updatedAt

  snapshot LeaderboardSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
  agent    Agent               @relation(fields: [agentAddress], references: [address], onDelete: Cascade)

  @@unique([snapshotId, agentAddress])
  @@index([snapshotId, rank])
  @@index([snapshotId, rankScore])
  @@index([snapshotId, owner])
  @@index([snapshotId, txCount])
  @@index([snapshotId, metricSource])
}

model ScorePipelineState {
  key       String   @id
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model WireQuote {
  id                           String               @id @default(cuid())
  quoteId                      String               @unique
  clientAddress                String?
  providerAddress              String
  evaluatorAddress             String
  chainId                      Int
  settlementAsset              WireSettlementAsset
  principalAmount              BigInt
  protocolFeeAmount            BigInt
  networkReserveAmount         BigInt
  networkReserveAsset          WireReserveAsset
  networkReserveDecimals       Int                  @default(18)
  displayReserveEstimateAmount BigInt?
  displayReserveEstimateAsset  WireSettlementAsset?
  jobType                      WireJobType          @default(SERVICE)
  ttlSeconds                   Int
  expiresAt                    DateTime
  consumedAt                   DateTime?
  createdAt                    DateTime             @default(now())

  job WireJob?

  @@index([expiresAt])
  @@index([consumedAt])
  @@index([chainId, settlementAsset, createdAt])
  @@index([providerAddress, createdAt])
}

model WireJob {
  id                   String                   @id @default(cuid())
  jobId                String                   @unique
  quoteId              String                   @unique
  chainId              Int
  jobExpiresAt         DateTime
  contractAddress      String?
  contractJobId        String?
  contractBudgetAmount BigInt
  clientAddress        String
  providerAddress      String
  evaluatorAddress     String
  settlementAsset      WireSettlementAsset
  principalAmount      BigInt
  protocolFeeAmount    BigInt
  networkReserveAmount BigInt
  networkReserveAsset  WireReserveAsset
  specHash             String
  metadataUri          String?
  contractState        WireContractState        @default(OPEN)
  publicState          WireContractState        @default(OPEN)
  terminalDisposition  WireTerminalDisposition?
  createTxHash         String?
  fundTxHash           String?
  terminalTxHash       String?
  webhookTargetUrl     String?
  webhookSecret        String?
  createdAt            DateTime                 @default(now())
  updatedAt            DateTime                 @updatedAt

  quote          WireQuote           @relation(fields: [quoteId], references: [quoteId], onDelete: Restrict)
  workflow       WireJobWorkflow?
  transitions    WireJobTransition[]
  operatorSpends WireOperatorSpend[]
  webhookOutbox  WireWebhookOutbox[]

  @@index([chainId, publicState, createdAt])
  @@index([clientAddress, createdAt])
  @@index([providerAddress, createdAt])
  @@index([evaluatorAddress, createdAt])
  @@index([jobExpiresAt])
  @@index([contractAddress, contractJobId])
}

model WireJobWorkflow {
  id                 String             @id @default(cuid())
  wireJobId          String             @unique
  createStatus       WireWorkflowStatus @default(PENDING)
  fundStatus         WireWorkflowStatus @default(PENDING)
  confirmationStatus WireWorkflowStatus @default(PENDING)
  reconcileStatus    WireWorkflowStatus @default(PENDING)
  lastError          String?
  lastAttemptAt      DateTime?
  retryCount         Int                @default(0)
  nextRetryAt        DateTime?
  manualReviewRequired Boolean          @default(false)
  manualReviewReason String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  wireJob WireJob @relation(fields: [wireJobId], references: [id], onDelete: Cascade)

  @@index([nextRetryAt])
  @@index([manualReviewRequired, nextRetryAt])
  @@index([reconcileStatus, nextRetryAt])
}

model WireJobTransition {
  id                         String             @id @default(cuid())
  wireJobId                  String
  eventId                    String             @unique
  fromState                  WireContractState?
  toState                    WireContractState
  sourceTxHash               String?
  sourceLogIndex             Int?
  blockNumber                BigInt?
  observedAt                 DateTime           @default(now())
  confirmedAt                DateTime?
  confirmationsAtObservation Int?

  wireJob WireJob @relation(fields: [wireJobId], references: [id], onDelete: Cascade)

  @@index([wireJobId, observedAt])
  @@index([wireJobId, toState, confirmedAt])
}

model WireOperatorSpend {
  id                String                 @id @default(cuid())
  wireJobId         String
  actionType        WireOperatorActionType
  txHash            String                 @unique
  nativeAsset       WireReserveAsset
  gasUsed           BigInt
  effectiveGasPrice BigInt
  nativeAmountSpent BigInt
  recordedAt        DateTime               @default(now())

  wireJob WireJob @relation(fields: [wireJobId], references: [id], onDelete: Cascade)

  @@index([wireJobId, recordedAt])
  @@index([actionType, recordedAt])
}

model WireWebhookOutbox {
  id             String                    @id @default(cuid())
  eventId        String                    @unique
  wireJobId      String
  eventType      String
  state          WireContractState
  contractState  WireContractState
  payloadJson    Json
  deliveryStatus WireWebhookDeliveryStatus @default(PENDING)
  attemptCount   Int                       @default(0)
  lastAttemptAt  DateTime?
  nextAttemptAt  DateTime?
  deliveredAt    DateTime?
  lastError      String?
  createdAt      DateTime                  @default(now())
  updatedAt      DateTime                  @updatedAt

  wireJob WireJob @relation(fields: [wireJobId], references: [id], onDelete: Cascade)

  @@index([deliveryStatus, nextAttemptAt])
  @@index([wireJobId, createdAt])
}
