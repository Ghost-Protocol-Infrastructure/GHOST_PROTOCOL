{
  "name": "ghost-rank-indexer",
  "private": true,
  "license": "MIT",
  "type": "module",
  "packageManager": "npm@10.8.2",
  "scripts": {
    "build:sdk": "npm --prefix packages/sdk run build",
    "index:db": "npx tsx scripts/index-db.ts",
    "index:db:erc8004": "npx tsx scripts/index-db.ts --mode=erc8004",
    "index:db:olas": "npx tsx scripts/index-db.ts --mode=olas",
    "index:db:full-reindex": "npx tsx scripts/index-db.ts --reset-indexer",
    "index:db:refresh-metadata": "npx tsx scripts/index-db.ts --force-refresh-metadata",
    "ingest:telemetry": "npx tsx scripts/ingest-telemetry-signals.ts",
    "score": "npx tsx scripts/score-leads.ts",
    "score:v2": "npx tsx scripts/score-v2.ts",
    "audit:score:clusters": "npx tsx scripts/audit-score-clusters.ts",
    "reconcile:credits": "npx tsx scripts/reconcile-credits.ts",
    "generate:fulfillment:fixtures": "npx tsx scripts/generate-fulfillment-fixtures.ts",
    "test:fulfillment:fixtures": "npx tsx scripts/verify-fulfillment-fixtures.ts",
    "test:fulfillment:api:negatives": "npx tsx scripts/test-fulfillment-api-negatives.ts",
    "test:fulfillment:regression": "npx tsx scripts/test-fulfillment-regression.ts",
    "monitor:credits": "npx tsx scripts/monitor-credit-alerts.ts",
    "test:credits:regression": "npx tsx scripts/test-credit-regression.ts",
    "verify:mcp:readonly": "npx tsx scripts/verify-mcp-readonly.ts",
    "benchmark:latency": "npx tsx scripts/benchmark-latency.ts",
    "benchmark:latency:quick": "npx tsx scripts/benchmark-latency.ts --iterations 10 --concurrency 2 --scenario mcp",
    "benchmark:latency:quick:paid": "npx tsx scripts/benchmark-latency.ts --iterations 10 --concurrency 2 --scenario gate,e2e",
    "typecheck": "tsc --noEmit",
    "contracts:compile": "npx -y node@22 .\\node_modules\\hardhat\\dist\\src\\cli.js compile",
    "contracts:deploy:vault:base-mainnet": "node scripts/deploy-vault.js --network=base-mainnet",
    "contracts:deploy:vault:base-sepolia": "node scripts/deploy-vault.js --network=base-sepolia",
    "contracts:deploy:ghostwire:base-mainnet": "node scripts/deploy-ghostwire-acp.js --network=base-mainnet",
    "contracts:deploy:ghostwire:base-sepolia": "node scripts/deploy-ghostwire-acp.js --network=base-sepolia",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "migrate:db": "npx tsx scripts/migrate-db.ts",
    "migrate:indexer": "npx tsx scripts/migrate-indexer.ts",
    "mcp:readonly": "node scripts/mcp-server.js",
    "check:lock": "npx npm@10.8.2 ci --ignore-scripts --no-audit --no-fund",
    "update-data": "npm run index:db",
    "postinstall": "prisma generate",
    "prepare": "husky"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.4.0",
    "@prisma/client": "^6.16.2",
    "@rainbow-me/rainbowkit": "^2.2.10",
    "@tanstack/react-query": "^5.90.20",
    "ethers": "^6.15.0",
    "lucide-react": "^0.563.0",
    "next": "16.1.6",
    "prisma": "^6.16.2",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "viem": "^2.21.0",
    "wagmi": "^2.19.5"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-node-test-runner": "^3.0.9",
    "@nomicfoundation/hardhat-verify": "^3.0.10",
    "@nomicfoundation/hardhat-viem": "^3.0.2",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20.11.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.2.4",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "hardhat": "^3.1.7",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "tailwindcss": "^4",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4"
  },
  "engines": {
    "node": ">=20 <21",
    "npm": "^10.8.2"
  },
  "lint-staged": {
    "package.json": [
      "node -e \"require('child_process').execSync('npx npm@10.8.2 install --package-lock-only --ignore-scripts', { stdio: 'inherit' })\"",
      "git add package-lock.json"
    ]
  }
}
